            </xs:simpleType>
            <xs:simpleType name="stText512">
                <xs:restriction base="xs:string">
                    <xs:minLength value="1"/>
                    <xs:maxLength value="512"/>
                </xs:restriction>
            </xs:simpleType>
            <xs:simpleType name="stText1024">
                <xs:restriction base="xs:string">
                    <xs:minLength value="1"/>
                    <xs:maxLength value="1024"/>
