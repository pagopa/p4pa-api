                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="identificativoUnivocoVersamento" type="pay_i:stText35">
                        <xs:annotation>
                            <xs:documentation>Il dato deve essere riportato invariato, a cura
                                del prestatore di servizi di pagamento, così come presente nei
                                Dovuti cui si riferisce
                                il messaggio dei Pagati.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="codiceContestoPagamento" type="pay_i:stText35">
                        <xs:annotation>
                            <xs:documentation>Il dato deve essere riportato invariato, a cura
                                del prestatore di servizi di pagamento, così come presente nei
                                Dovuti cui si riferisce
                                il messaggio dei Pagati.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" maxOccurs="5" name="datiSingoloPagamento"
                                type="pay_i:ctDatiSingoloPagamentoPagatiConRicevuta">
                        <xs:annotation>
                            <xs:documentation>Aggregazione “dati dei singoli versamenti”, da
                                un minimo di uno ad un massimo di 5 occorrenze di versamento,
                                facenti capo ad un unico
                                identificativoUnivocoVersamento.
                            </xs:documentation>
                            <xs:documentation>Obbligatorio nel caso che l’elemento
                                codiceEsitoPagamento sia 0 o 2
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
            <xs:complexType name="ctDatiVersamento">
                <xs:sequence>
                    <xs:element minOccurs="0" name="dataEsecuzionePagamento" type="pay_i:stISODate">
                        <xs:annotation>
                            <xs:documentation>Indica la data in cui si richiede che venga
                                effettuato il pagamento secondo il formato ISO 8601
                                [YYYY]-[MM]-[DD].
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="tipoVersamento" type="pay_i:stText32">
                        <xs:annotation>
                            <xs:documentation>Forma tecnica di pagamento delle somme dovute
                                presso la Tesoreria Statale. Può assumere i seguenti valori:
                            </xs:documentation>
                            <xs:documentation>- BBT - Bonifico Bancario di Tesoreria.
                            </xs:documentation>
                            <xs:documentation>- BP - Bonifico Postale.</xs:documentation>
                            <xs:documentation>- AD - Addebito diretto.</xs:documentation>
                            <xs:documentation>- CP - Carta di Pagamento.</xs:documentation>
                            <xs:documentation>- PO - Pagamento attivato presso PSP.
                            </xs:documentation>
                            <xs:documentation>- OBEP - On-line Banking E-Payment.
                            </xs:documentation>
                            <xs:documentation>La stringa può essere composta da più tipi
                                versamento, intervallati dal carattere 'pipe' ('|'), in
                                alternativa dal testo speciale 'ALL'
                                se prevede tutti e sei i tipi.
                                Se non indicato viene preso il default dalle configurazioni
                                dell'ente
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="identificativoUnivocoVersamento" type="pay_i:stText35">
                        <xs:annotation>
                            <xs:documentation>Indica il codice univoco versamento
                                eventualmente generato (secondo il formato iuv
                                “Formato IUV 17 Ente”) dalla PA ed assegnato al dovuto;
                                uno IUV può essere associato ad uno ed un solo IUD
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="identificativoUnivocoDovuto" type="pay_i:stText35">
                        <xs:annotation>
                            <xs:documentation>Indica il codice univoco di un dovuto generato
                                dalla PA (Identificativo Unico Dovuto); non può essere ripetuto
                                all'interno dello stesso
                                flusso mentre si può ripetere in flussi
                                diversi per azioni di modifica od annullamento di un dovuto
                                precedentemente inviato (vedi campo 'azione'); i
                                primi tre
                                caratteri devono essere diversi da “000”
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="importoSingoloVersamento" type="pay_i:stImportoPositivo">
                        <xs:annotation>
                            <xs:documentation>Campo numerico (due cifre per la parte decimale,
                                il separatore dei centesimi è il punto “.”), indicante l’importo
                                relativo alla somma da
                                versare. Deve essere diverso da “0.00”.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="commissioneCaricoPA" type="pay_i:stImporto">
                        <xs:annotation>
                            <xs:documentation>Campo numerico (due cifre per la parte decimale,
                                il separatore dei centesimi è il punto “.”), indicante l’importo
                                relativo alla somma da
                                versare. Il data è riportato a solo titolo
                                indicativo e non comporta attività a carico del PSP. Se presente
                                deve essere diverso da “0.00”.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="identificativoTipoDovuto" type="pay_i:stText64">
                        <xs:annotation>
                            <xs:documentation>Riferimento alla tipologia del dovuto secondo la
                                classificazione data dal beneficiario.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="causaleVersamento" type="pay_i:stText1024">
                        <xs:annotation>
                            <xs:documentation>Rappresenta la descrizione estesa della causale
                                del versamento.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="datiSpecificiRiscossione" type="pay_i:stDatiSpecificiRiscossione">
                        <xs:annotation>
                            <xs:documentation>Rappresenta l’indicazione dell’imputazione della
                                specifica entrata ed è così articolato:
                            </xs:documentation>
                            <xs:documentation>"tipo contabilità"/"codice contabilità", dove
                                "tipo contabilità" può assumere i seguenti valori :
                            </xs:documentation>
                            <xs:documentation>0 Capitolo e articolo di Entrata del Bilancio
                                dello stato
                            </xs:documentation>
                            <xs:documentation>1 Numero della contabilità speciale
                            </xs:documentation>
                            <xs:documentation>2 Codice SIOPE</xs:documentation>
                            <xs:documentation>9 Altro codice ad uso dell’amministrazione
                            </xs:documentation>
                            <xs:documentation>Esempio: 0/3321.00 per indicare il Contributo
                                Unificato delle spese di giustizia
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="bilancio" type="pay_i:ctBilancio">
                        <xs:annotation>
                            <xs:documentation>Bilancio opzionale del dovuto
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
            <xs:complexType name="ctDovuti">
                <xs:sequence>
                    <xs:element minOccurs="1" name="versioneOggetto" type="pay_i:stText16">
                        <xs:annotation>
                            <xs:documentation>Versione che identifica l’oggetto scambiato.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="soggettoPagatore" type="pay_i:ctSoggettoPagatore">
                        <xs:annotation>
                            <xs:documentation>Aggregazione “soggetto pagatore” che riporta le
                                informazioni concernenti il soggetto che effettua il pagamento.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="datiVersamento" type="pay_i:ctDatiVersamentoDovuti">
                        <xs:annotation>
                            <xs:documentation>Aggregazione “dati del versamento”.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
            <xs:complexType name="ctDovutiEntiSecondari">
                <xs:sequence>
                    <xs:element minOccurs="1" name="versioneOggetto" type="pay_i:stText16">
                        <xs:annotation>
                            <xs:documentation>Versione che identifica l’oggetto scambiato.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="datiVersamentoEntiSecondari"
                                type="pay_i:ctDatiVersamentoDovutiEntiSecondari">
                        <xs:annotation>
                            <xs:documentation>Aggregazione “dati del versamento” per un pagamento multibeneficiario.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
            <xs:complexType name="ctPagati">
                <xs:sequence>
                    <xs:element minOccurs="1" name="versioneOggetto" type="pay_i:stText16">
                        <xs:annotation>
                            <xs:documentation>Riporta la stessa informazione presente nel dato
                                “versioneOggetto” dei Dovuti.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="dominio" type="pay_i:ctDominio">
                        <xs:annotation>
                            <xs:documentation>Riporta le stesse informazioni presenti nel
                                blocco “Dominio” dei Dovuti
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="identificativoMessaggioRicevuta" type="pay_i:stText35">
                        <xs:annotation>
                            <xs:documentation>Identificativo legato alla trasmissione della
                                quietanza telematica.
                            </xs:documentation>
                            <xs:documentation>Deve essere univoco nell’ambito della stessa
                                data riferita all’elemento dataMessaggioRicevuta.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="dataOraMessaggioRicevuta" type="pay_i:stISODateTime">
                        <xs:annotation>
                            <xs:documentation>Indica la data del messaggio di quietanza,
                                secondo il formato ISO 8601
                            </xs:documentation>
                            <xs:documentation>[YYYY]-[MM]-[DD]T[hh]:[mm]:[ss]
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="riferimentoMessaggioRichiesta" type="pay_i:stText35">
                        <xs:annotation>
                            <xs:documentation>Con riferimento al messaggio dei Pagati
                                l’elemento contiene il dato identificativoMessaggioRichiesta
                                legato alla trasmissione dei
                                Dovuti.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="riferimentoDataRichiesta" type="pay_i:stISODate">
                        <xs:annotation>
                            <xs:documentation>Indica la data secondo il formato ISO 8601
                                [YYYY]-[MM]-[DD] cui si riferisce la generazione del dato
                                riferimentoMessaggioRichiesta.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="istitutoAttestante" type="pay_i:ctIstitutoAttestante">
                        <xs:annotation>
                            <xs:documentation>Aggregazione relativa al soggetto Prestatore dei
                                servizi di Pagamento che emette il documento di attestazione
                                dell’avvenuto versamento.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="enteBeneficiario" type="pay_i:ctEnteBeneficiario">
                        <xs:annotation>
                            <xs:documentation>Riporta le stesse informazioni presenti nel
                                blocco “Ente Beneficiario” dei Dovuti cui si riferisce il
                                messaggio dei Pagati.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="soggettoPagatore" type="pay_i:ctSoggettoPagatore">
                        <xs:annotation>
                            <xs:documentation>Riporta le stesse informazioni presenti nel
                                blocco “Soggetto Pagatore” dei Dovuti cui si riferisce il
                                messaggio dei Pagati.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="datiPagamento" type="pay_i:ctDatiVersamentoPagati">
                        <xs:annotation xml:base="pay_i:stImporto">
                            <xs:documentation>Aggregazione “dati del versamento”
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
            <xs:complexType name="ctPagatiConRicevuta">
                <xs:sequence>
                    <xs:element minOccurs="1" name="versioneOggetto" type="pay_i:stText16">
                        <xs:annotation>
                            <xs:documentation>Riporta la stessa informazione presente nel dato
                                “versioneOggetto” dei Dovuti.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="dominio" type="pay_i:ctDominio">
                        <xs:annotation>
                            <xs:documentation>Riporta le stesse informazioni presenti nel
                                blocco “Dominio” dei Dovuti
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="identificativoMessaggioRicevuta" type="pay_i:stText35">
                        <xs:annotation>
                            <xs:documentation>Identificativo legato alla trasmissione della
                                quietanza telematica.
                            </xs:documentation>
                            <xs:documentation>Deve essere univoco nell’ambito della stessa
                                data riferita all’elemento dataMessaggioRicevuta.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="dataOraMessaggioRicevuta" type="pay_i:stISODateTime">
                        <xs:annotation>
                            <xs:documentation>Indica la data del messaggio di quietanza,
                                secondo il formato ISO 8601
                            </xs:documentation>
                            <xs:documentation>[YYYY]-[MM]-[DD]T[hh]:[mm]:[ss]
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="riferimentoMessaggioRichiesta" type="pay_i:stText35">
                        <xs:annotation>
                            <xs:documentation>Con riferimento al messaggio dei Pagati
                                l’elemento contiene il dato identificativoMessaggioRichiesta
                                legato alla trasmissione dei
                                Dovuti.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="riferimentoDataRichiesta" type="pay_i:stISODate">
                        <xs:annotation>
                            <xs:documentation>Indica la data secondo il formato ISO 8601
                                [YYYY]-[MM]-[DD] cui si riferisce la generazione del dato
                                riferimentoMessaggioRichiesta.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="istitutoAttestante" type="pay_i:ctIstitutoAttestante">
                        <xs:annotation>
                            <xs:documentation>Aggregazione relativa al soggetto Prestatore dei
                                servizi di Pagamento che emette il documento di attestazione
                                dell’avvenuto versamento.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="enteBeneficiario" type="pay_i:ctEnteBeneficiario">
                        <xs:annotation>
                            <xs:documentation>Riporta le stesse informazioni presenti nel
                                blocco “Ente Beneficiario” dei Dovuti cui si riferisce il
                                messaggio dei Pagati.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="soggettoPagatore" type="pay_i:ctSoggettoPagatore">
                        <xs:annotation>
                            <xs:documentation>Riporta le stesse informazioni presenti nel
                                blocco “Soggetto Pagatore” dei Dovuti cui si riferisce il
                                messaggio dei Pagati.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="datiPagamento" type="pay_i:ctDatiVersamentoPagatiConRicevuta">
                        <xs:annotation xml:base="pay_i:stImporto">
                            <xs:documentation>Aggregazione “dati del versamento”
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
            <xs:complexType name="ctVersamento">
                <xs:sequence>
                    <xs:element minOccurs="1" name="versioneOggetto" type="pay_i:stText16">
                        <xs:annotation>
                            <xs:documentation>Versione che identifica l’oggetto scambiato.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="soggettoPagatore" type="pay_i:ctSoggettoPagatore">
                        <xs:annotation>
                            <xs:documentation>Aggregazione “soggetto pagatore” che riporta le
                                informazioni concernenti il soggetto che effettua il pagamento.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="datiVersamento" type="pay_i:ctDatiVersamento">
                        <xs:annotation>
                            <xs:documentation>Aggregazione “dati del versamento”.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="azione" type="pay_i:stText1">
                        <xs:annotation>
                            <xs:documentation>Indica l'operazione da compiere sul dovuto. I
                                valori possibili e le relative descrizioni sono:
                                'I' indica che il dovuto deve essere inserito
                                'M' indica che il dovuto deve essere modificato
                                'A' indica che il dovuto deve essere annullato
                                '9' indica codice 9 (annullamento dovuto)
                                'S' viene solo stampato l'avviso
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
            <xs:complexType name="ctAccertamento">
                <xs:sequence>
                    <xs:element minOccurs="0" name="codAccertamento" type="pay_i:stText64">
                        <xs:annotation>
                            <xs:documentation>Codice dell' accertamento obbligatorio, al limite vuoto
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="importo" type="pay_i:stImportoPositivo">
                        <xs:annotation>
                            <xs:documentation>Importo dell' accertamento. Campo numerico (due cifre per la parte
                                decimale,
                                il separatore dei centesimi è il punto “.”), indicante l’importo
                                relativo alla somma da
                                versare. Deve essere diverso da “0.00”.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
