                        <xs:annotation>
                            <xs:documentation>Campo alfanumerico che indica la natura del
                                soggetto, può assumere i seguenti valori:
                            </xs:documentation>
                            <xs:documentation>F - Persona Fisica</xs:documentation>
                            <xs:documentation>G - Persona Giuridica</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="codiceIdentificativoUnivoco" type="pay_i:stText35">
                        <xs:annotation>
                            <xs:documentation>Campo alfanumerico che può contenere il codice
                                fiscale o, in alternativa, la partita IVA del soggetto.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
            <xs:complexType name="ctIdentificativoUnivocoPersonaG">
                <xs:sequence>
                    <xs:element minOccurs="1" name="tipoIdentificativoUnivoco"
                                type="pay_i:stTipoIdentificativoUnivocoPersG">
                        <xs:annotation>
                            <xs:documentation>Campo alfanumerico che indica la natura del
                                soggetto, può assumere i seguenti valori:
                            </xs:documentation>
                            <xs:documentation>G - Persona Giuridica</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="codiceIdentificativoUnivoco" type="pay_i:stText35">
                        <xs:annotation>
                            <xs:documentation>Campo alfanumerico che può contenere il codice
                                fiscale o, in alternativa, la partita IVA del soggetto.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
            <xs:complexType name="ctSoggettoPagatore">
                <xs:sequence>
                    <xs:element minOccurs="1" name="identificativoUnivocoPagatore"
                                type="pay_i:ctIdentificativoUnivocoPersonaFG">
                        <xs:annotation>
                            <xs:documentation>Aggregazione che riporta le informazioni
                                concernenti l’identificazione fiscale del pagatore.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" name="anagraficaPagatore" type="pay_i:stText70">
                        <xs:annotation>
                            <xs:documentation>Indica il nominativo o la ragione sociale del
                                pagatore.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="indirizzoPagatore" type="pay_i:stText70">
                        <xs:annotation>
                            <xs:documentation>Indica l’indirizzo del pagatore.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="civicoPagatore" type="pay_i:stText16">
                        <xs:annotation>
                            <xs:documentation>Indica il numero civico del pagatore.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="capPagatore" type="pay_i:stText16">
                        <xs:annotation>
                            <xs:documentation>Indica il CAP del pagatore.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="localitaPagatore" type="pay_i:stText35">
                        <xs:annotation>
                            <xs:documentation>Indica la località del pagatore.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="provinciaPagatore" type="pay_i:stText2">
                        <xs:annotation>
                            <xs:documentation>Indica la provincia del pagatore.
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="nazionePagatore" type="pay_i:stNazione">
                        <xs:annotation>
