                <xs:sequence>
                    <xs:element minOccurs="1" name="codCapitolo" type="pay_i:stText64">
                        <xs:annotation>
                            <xs:documentation>Codice del capitolo, obbligatorio
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" name="codUfficio" type="pay_i:stText64">
                        <xs:annotation>
                            <xs:documentation>Codice dell' ufficio da cui il capitolo dipende, non obbligatorio
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="1" maxOccurs="unbounded" name="accertamento" type="pay_i:ctAccertamento">
                        <xs:annotation>
                            <xs:documentation>Aggregazione di "accertamento"
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
            <xs:complexType name="ctBilancio">
                <xs:sequence>
                    <xs:element minOccurs="1" maxOccurs="unbounded" name="capitolo" type="pay_i:ctCapitolo">
                        <xs:annotation>
                            <xs:documentation>Aggregazione di "capitolo"
                            </xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
            <xs:element name="Dovuti" type="pay_i:ctDovuti">
                <xs:annotation>
                    <xs:documentation>Dovuti</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="DovutiEntiSecondari" type="pay_i:ctDovutiEntiSecondari">
                <xs:annotation>
                    <xs:documentation>DovutiEntiSecondari</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Pagati" type="pay_i:ctPagati">
                <xs:annotation>
                    <xs:documentation>Pagati</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PagatiConRicevuta" type="pay_i:ctPagatiConRicevuta">
                <xs:annotation>
                    <xs:documentation>Pagati</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Versamento" type="pay_i:ctVersamento">
                <xs:annotation>
                    <xs:documentation>Versamento</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="bilancio" type="pay_i:ctBilancio">
                <xs:annotation>
                    <xs:documentation>Bilancio</xs:documentation>
                </xs:annotation>
            </xs:element><!--FROM: 'PagInf_Dovuti_Pagati_6_2_0.xsd' END-->
